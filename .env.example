# Copy this file to .env.local and fill in your values

# Supabase — find these in your project: Settings > API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Google OAuth — configure in Supabase Auth > Providers > Google
# (No env vars needed here — configured in Supabase dashboard)

# EmailJS — for custom email OTP (account confirmation)
# 1. Sign up at https://www.emailjs.com
# 2. Create a service (Gmail, SMTP, etc.) → copy the Service ID
# 3. Create an email template with variables: {{to_email}}, {{otp_code}}, {{user_name}}
#    → copy the Template ID
# 4. Account > API Keys → copy the Public Key
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxx

# Template for payment notification (sent when admin approves booking → pending_payment)
# Variables: to_name, to_email, booking_id, band_name, session_type,
#            booking_date, start_time, end_time, amount,
#            gcash_number, gcash_name, qr_code_url
VITE_EMAILJS_TEMPLATE_PAYMENT=template_xxxxxxx

# Template for invoice (sent by admin after payment is confirmed)
# Variables: to_name, to_email, booking_id, band_name, session_type,
#            booking_date, start_time, end_time, amount
VITE_EMAILJS_TEMPLATE_INVOICE=template_xxxxxxx
